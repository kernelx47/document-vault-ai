# App
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
SECRET_KEY=change-me

# Database
DATABASE_URL=postgresql+asyncpg://postgres:postgres@localhost:5432/document_vault

# Redis / Celery
REDIS_URL=redis://localhost:6379/0
CELERY_BROKER_URL=redis://localhost:6379/0
CELERY_RESULT_BACKEND=redis://localhost:6379/1

# Storage
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=20
MAX_BATCH_UPLOAD_FILES=25
MAX_MULTI_DOC_CHAT_DOCUMENTS=10
UPLOAD_RATE_LIMIT_PER_MINUTE=30
CHAT_RATE_LIMIT_PER_MINUTE=60
DAILY_AI_REQUEST_QUOTA=1000
EMBEDDING_BATCH_SIZE=32

# AI cost estimates (USD per 1M tokens — for metrics only)
OPENAI_INPUT_COST_PER_1M_TOKENS=0.15
OPENAI_OUTPUT_COST_PER_1M_TOKENS=0.60
GEMINI_INPUT_COST_PER_1M_TOKENS=0.075
GEMINI_OUTPUT_COST_PER_1M_TOKENS=0.30

# Logging
LOG_LEVEL=INFO

# AI providers
EMBEDDING_PROVIDER=local
LLM_PROVIDER=openai
OPENAI_API_KEY=sk-your-key-here
OPENAI_MODEL=gpt-4o-mini
GEMINI_API_KEY=
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=llama3.2

# RAG
CHUNK_SIZE=800
CHUNK_OVERLAP=150
RAG_TOP_K=5
EMBEDDING_DIMENSION=384

# Frontend
NEXT_PUBLIC_API_URL=http://localhost:8000/api/v1
